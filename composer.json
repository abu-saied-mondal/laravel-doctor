{
    "name": "devski/laravel-doctor",
    "description": "An open-source diagnostics and repair toolkit for Laravel applications.",
    "license": "MIT",
    "authors": [
        {
            "name": "Abu Saied Mondal",
            "homepage": "https://github.com/abu-saied-mondal"
        }
    ],
    "require": {
        "php": "^8.1 || ^8.2 || ^8.3",
        "illuminate/support": "^9.0 || ^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/console": "^9.0 || ^10.0 || ^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^7.0 || ^8.0 || ^9.0",
        "phpunit/phpunit": "^9.5 || ^10.0"
    },
    "autoload": {
        "psr-4": {
            "LaravelDoctor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaravelDoctor\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelDoctor\\LaravelDoctorServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
